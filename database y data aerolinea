        pesos_rutas.append(1)
# ===============================================
# TEMPORADAS
# ===============================================

def obtener_factor_demanda(fecha):

    calendario = {

        1: 1.15,   # Vacaciones
        2: 0.72,   # Temporada baja
        3: 1.05,
        4: 1.25,   # Semana Santa
        5: 0.95,
        6: 1.35,   # Vacaciones
        7: 1.45,
        8: 1.10,
        9: 0.82,
        10: 0.75,
        11: 1.00,
        12: 1.55   # Navidad
    }

    return calendario[fecha.month]

# ===============================================
# ESTADO DEL VUELO
# ===============================================

def generar_estado(perfil):

    return random.choices(

        [

            "A Tiempo",

            "Retrasado",

            "Cancelado"

        ],

        weights=perfil["estado"]

    )[0]

# ===============================================
# MINUTOS DE RETRASO
# ===============================================

def generar_retraso(estado,perfil):

    if estado=="A Tiempo":

        return 0

    if estado=="Cancelado":

        return random.randint(60,180)

    return random.randint(

        perfil["retraso"][0],

        perfil["retraso"][1]

    )

# ===============================================
# REGENERAR VUELOS V3
# ===============================================

vuelos = []

id_vuelo = 1

for _, fila_fecha in df_tiempo.iterrows():

    fecha = fila_fecha["id_fecha"]

    temporada = obtener_factor_demanda(fecha)
    
    dia = fecha.weekday()

    factor_dia = 1
    if dia == 4:      # Viernes

        factor_dia = 1.08

    elif dia == 6:    # Domingo

        factor_dia = 1.12

    elif dia == 0:    # Lunes

        factor_dia = 0.95
    vuelos_hoy = max(
        3,
        int(VUELOS_DIARIOS * temporada)
    )

    for _ in range(vuelos_hoy):

        # -------------------------------------
        # Seleccionar ruta
        # -------------------------------------

        ruta = df_rutas.sample(
            weights=pesos_rutas
        ).iloc[0]

        perfil = perfil_rutas[ruta["id_ruta"]]

        # -------------------------------------
        # Aeronave asignada por ruta
        # -------------------------------------

        aeronave = df_aeronaves.loc[
            df_aeronaves["id_aeronave"] ==
            perfil["aeronave"]
        ].iloc[0]

        # -------------------------------------
        # Hora salida
        # -------------------------------------

        hora = random.randint(5,22)

        minuto = random.choice(
            [0,15,30,45]
        )

        # -------------------------------------
        # Estado
        # -------------------------------------

        estado = generar_estado(perfil)

        retraso = generar_retraso(
            estado,
            perfil
        )
        if fecha.month in [6,7,12]:

            retraso = int(retraso * 1.25)

        elif fecha.month in [2,10]:

            retraso = int(retraso * 0.75)
        # -------------------------------------
        # Load Factor
        # -------------------------------------

        base = random.randint(
            perfil["load"][0],
            perfil["load"][1]
        )

        ocupacion = int(
            base *
            temporada *
            factor_dia
        )

        if fecha.month in [6,7,12]:
            ocupacion += random.randint(2,6)
        elif fecha.month in [2,10]:
            ocupacion -= random.randint(4,8)

        ocupacion = max(55, min(99, ocupacion))

        vendidos = int(
            aeronave["capacidad"] *
            ocupacion / 100
        )

        # -------------------------------------
        # Construcción registro
        # -------------------------------------

        vuelos.append({

            "id_vuelo":

                id_vuelo,

            "id_ruta":

                ruta["id_ruta"],

            "id_aeronave":

                aeronave["id_aeronave"],

            "fecha_hora_salida":

                datetime(

                    fecha.year,

                    fecha.month,

                    fecha.day,

                    hora,

                    minuto

                ),

            "estado_vuelo":

                estado,

            "minutos_retraso":

                retraso,

            "capacidad":

                aeronave["capacidad"],

            "asientos_vendidos":

                vendidos,

            "load_factor":

                ocupacion,

            "costo_minuto":

                aeronave["costo_retraso_minuto"]

        })

        id_vuelo += 1

df_vuelos = pd.DataFrame(vuelos)

