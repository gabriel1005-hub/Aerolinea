fact = []

id_reserva = 1

for _, vuelo in df_vuelos.iterrows():

    perfil = perfil_rutas[vuelo["id_ruta"]]

    if perfil["perfil"]=="PREMIUM":

        eco=(180,260)
        premium=(350,500)
        business=(700,950)

    elif perfil["perfil"]=="ALTA":

        eco=(160,230)
        premium=(310,430)
        business=(620,850)

    elif perfil["perfil"]=="MEDIA":

        eco=(130,190)
        premium=(250,360)
        business=(500,700)

    else:

        eco=(95,145)
        premium=(180,260)
        business=(360,520)

    # ==========================================
    # DISTRIBUCIÓN DE TARIFAS
    # ==========================================

    if perfil["perfil"]=="PREMIUM":

        pesos=[72,20,8]

    elif perfil["perfil"]=="ALTA":

        pesos=[80,15,5]

    elif perfil["perfil"]=="MEDIA":

        pesos=[89,8,3]

    else:

        pesos=[95,4,1]

    # ==========================================
    # COSTO TOTAL DEL VUELO
    # ==========================================

    if perfil["perfil"] == "PREMIUM":

        factor_congestion = 2.2
        costo_fijo = 1200

    elif perfil["perfil"] == "ALTA":

        factor_congestion = 1.8
        costo_fijo = 900

    elif perfil["perfil"] == "MEDIA":

        factor_congestion = 1.3
        costo_fijo = 600

    else:

        factor_congestion = 0.9
        costo_fijo = 250
    
    aeronave = df_aeronaves.loc[
        df_aeronaves["id_aeronave"] ==
        vuelo["id_aeronave"]
    ].iloc[0]
    costo_total_vuelo = (

        costo_fijo +

        (

            vuelo["minutos_retraso"] *

            vuelo["costo_minuto"] *

            factor_congestion 

        ) +

        (

            aeronave["consumo_combustible_hora"] / 70

        )

    )

    if vuelo["estado_vuelo"] == "Cancelado":

        costo_total_vuelo += vuelo["asientos_vendidos"] * 120
        costo_total_vuelo *= 2
        

    elif vuelo["estado_vuelo"] == "Retrasado":

        costo_total_vuelo *= 1.75

    costo_por_reserva = round(

        costo_total_vuelo /

        (vuelo["asientos_vendidos"] * 0.80),

        2

    )

    # ==========================================
    # RESERVAS
    # ==========================================

    for _ in range(vuelo["asientos_vendidos"]):

        pasajero = random.choices(

            pasajeros_frecuentes +

            pasajeros_normales,

            weights=

            [5]*len(pasajeros_frecuentes)

            +

            [1]*len(pasajeros_normales)

        )[0]

        tarifa = random.choices(

            [1,2,3],

            weights=pesos

        )[0]

        # ======================================
        # PRECIO VARIABLE
        # ======================================

        if tarifa==1:

            precio=random.randint(*eco)

        elif tarifa==2:

            precio=random.randint(*premium)

        else:

            precio=random.randint(*business)
        
        if vuelo["load_factor"] >= 95:

            precio *= 1.20

        elif vuelo["load_factor"] >= 90:

            precio *= 1.10

        mes = vuelo["fecha_hora_salida"].month

        if mes in [6,7,12]:

            precio *= 1.12

        elif mes in [2,10]:

            precio *= 0.80

        precio = round(precio)
        # ======================================
        # ESTADO RESERVA
        # ======================================

        if vuelo["estado_vuelo"]=="Cancelado":

            estado="Cancelada"

        elif vuelo["estado_vuelo"]=="Retrasado":

            estado=random.choice([

                "Check-In",

                "Completada"

            ])

        else:

            estado=random.choice([

                "Confirmada",

                "Completada",

                "Check-In"

            ])

        # ======================================
        # INGRESOS
        # ======================================

        ingreso = precio

        # ======================================
        # COSTO INEFICIENCIA
        # ======================================

        costo = costo_por_reserva

        # ======================================
        # MARGEN
        # ======================================

        margen = round(

            ingreso -

            costo,

            2

        )

        fact.append({

            "id_reserva":

                id_reserva,

            "id_pasajero":

                pasajero,

            "id_tarifa":

                tarifa,

            "id_vuelo":

                vuelo["id_vuelo"],

            "id_ruta":

                vuelo["id_ruta"],

            "id_aeronave":

                vuelo["id_aeronave"],

            "id_fecha":

                vuelo["fecha_hora_salida"].date(),

            "precio_pagado":

                precio,

            "estado_reserva":

                estado,

            "asientos_ofertados":

                vuelo["capacidad"],

            "asientos_vendidos":

                vuelo["asientos_vendidos"],

            "load_factor":

                vuelo["load_factor"],

            "minutos_retraso":

                vuelo["minutos_retraso"],

            "costo_ineficiencia":

                costo,

            "ingresos_brutos":

                ingreso,

            "margen_operativo":

                margen

        })

        id_reserva += 1

df_fact = pd.DataFrame(fact)

